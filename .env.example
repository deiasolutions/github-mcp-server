# Server
PORT=3000
NODE_ENV=production

# Database (Railway provides DATABASE_URL)
DATABASE_URL=postgresql://...

# GitHub OAuth App
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret
GITHUB_CALLBACK_URL=https://github-mcp.simdecisions.com/oauth/callback

# Encryption
TOKEN_ENCRYPTION_KEY=32-byte-hex-key-for-aes-256

# Optional: Restrict to specific users/origins
ALLOWED_ORIGINS=https://shiftcenter.simdecisions.com
